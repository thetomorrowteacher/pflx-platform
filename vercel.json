{
  "rewrites": [
    { "source": "/", "destination": "/preview.html" },
    { "source": "/landing", "destination": "/landing.html" },
    { "source": "/favicon.ico", "destination": "/public/PFLX Core Flat 6.png" },
    { "source": "/p/:brand", "destination": "/preview.html" },
    { "source": "/:brand", "destination": "/preview.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "ALLOWALL" },
        { "key": "Content-Security-Policy", "value": "frame-ancestors *" }
      ]
    },
    {
      "source": "/(preview|landing|index)\\.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" }
      ]
    },
    {
      "source": "/public/Loading Screen Images/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=3600, must-revalidate" }
      ]
    }
  ]
}
